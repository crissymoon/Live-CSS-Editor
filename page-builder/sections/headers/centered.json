{
    "_meta": {
        "name": "Centered Header",
        "type": "header",
        "description": "Centered brand with nav below"
    },
    "type": "header",
    "settings": {
        "bg":          "#0a0a14",
        "borderColor": "rgba(255,255,255,0.06)",
        "height":      "72px",
        "maxWidth":    "900px",
        "padding":     "0 24px"
    },
    "brand": {
        "text":        "STUDIO",
        "href":        "#",
        "color":       "#e8e8f0",
        "fontSize":    "18px",
        "fontWeight":  "600",
        "letterSpacing": "0.2em"
    },
    "nav": [
        { "label": "Projects", "href": "#" },
        { "label": "About",    "href": "#" },
        { "label": "Blog",     "href": "#" },
        { "label": "Hire Us",  "href": "#", "cta": true }
    ],
    "navSettings": {
        "linkColor":  "#8888a0",
        "ctaColor":   "#c7c7f0",
        "ctaBorder":  "rgba(199,199,240,0.4)",
        "gap":        "8px",
        "fontSize":   "11px",
        "navCollapseAt": 600
    }
}
