{
    "_meta": {
        "name": "Agency Header - Multi Dropdown",
        "type": "header",
        "description": "Wide agency nav with multiple dropdowns across all top-level items"
    },
    "type": "header",
    "settings": {
        "bg":          "#0a0a14",
        "borderColor": "rgba(255,255,255,0.07)",
        "height":      "60px",
        "maxWidth":    "1200px",
        "padding":     "0 32px"
    },
    "brand": {
        "text":          "AGENCY",
        "href":          "/",
        "color":         "#e2e2f0",
        "fontSize":      "14px",
        "fontWeight":    "700",
        "letterSpacing": "0.18em"
    },
    "nav": [
        {
            "label": "Company",
            "href": "#",
            "dropdown": [
                { "label": "About Us",       "href": "#about" },
                { "label": "Our Team",       "href": "#team" },
                { "label": "Careers",        "href": "#careers" },
                { "separator": true },
                { "label": "Press",          "href": "#press" }
            ]
        },
        {
            "label": "Services",
            "href": "#",
            "dropdown": [
                { "label": "Strategy",       "href": "#strategy" },
                { "label": "Design",         "href": "#design" },
                { "label": "Engineering",    "href": "#engineering" },
                { "label": "Growth",         "href": "#growth" },
                { "separator": true },
                { "label": "All Services",   "href": "#services" }
            ]
        },
        {
            "label": "Work",
            "href": "#",
            "dropdown": [
                { "label": "Case Studies",   "href": "#case-studies" },
                { "label": "Portfolio",      "href": "#portfolio" },
                { "label": "Clients",        "href": "#clients" }
            ]
        },
        {
            "label": "Resources",
            "href": "#",
            "dropdown": [
                { "label": "Blog",           "href": "#blog" },
                { "label": "Documentation",  "href": "#docs" },
                { "label": "Changelog",      "href": "#changelog" }
            ]
        },
        { "label": "Get in Touch", "href": "#contact", "cta": true }
    ],
    "navSettings": {
        "linkColor":        "#8888b0",
        "ctaColor":         "#c7c7f0",
        "ctaBorder":        "rgba(199,199,240,0.35)",
        "dropdownBg":       "#0f0f1c",
        "dropdownColor":    "#9090b0",
        "dropdownFontSize": "12px",
        "gap":              "2px",
        "fontSize":         "12px",
        "navCollapseAt":    768
    }
}
