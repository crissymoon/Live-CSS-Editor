{
    "_meta": {
        "name": "Blog - Pagination",
        "type": "section",
        "description": "Pagination bar with previous, current page indicator, and next buttons"
    },
    "type": "section",
    "id": "blog-pagination",
    "layout": "row",
    "settings": {
        "bg":      "#0a0a14",
        "padding": "0 24px 80px",
        "maxWidth": "720px",
        "align":   "center",
        "gap":     "12px",
        "columns": 3
    },
    "blocks": [
        {
            "type": "button",
            "id":   "pag-prev",
            "text": "Previous",
            "href": "#",
            "settings": {
                "bg":            "#0d0d18",
                "color":         "#a5a5c0",
                "padding":       "10px 22px",
                "fontSize":      "13px",
                "fontWeight":    "500",
                "borderRadius":  "0",
                "letterSpacing": "0.04em"
            }
        },
        {
            "type": "text",
            "id":   "pag-indicator",
            "text": "Page 1 of 6",
            "settings": {
                "color":         "#5555a0",
                "fontSize":      "12px",
                "letterSpacing": "0.06em",
                "textAlign":     "center"
            }
        },
        {
            "type": "button",
            "id":   "pag-next",
            "text": "Next",
            "href": "#",
            "settings": {
                "bg":            "#6366f1",
                "color":         "#ffffff",
                "padding":       "10px 22px",
                "fontSize":      "13px",
                "fontWeight":    "600",
                "borderRadius":  "0",
                "letterSpacing": "0.04em"
            }
        }
    ]
}
