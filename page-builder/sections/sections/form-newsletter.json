{
    "_meta": {
        "name": "Form - Newsletter Signup",
        "type": "section",
        "description": "Simple email signup form with a single input and subscribe button"
    },
    "type": "section",
    "id": "newsletter",
    "layout": "column",
    "settings": {
        "bg":        "#111122",
        "borderTop": "1px solid rgba(99,102,241,0.15)",
        "padding":   "64px 24px",
        "maxWidth":  "520px",
        "align":     "center",
        "gap":       "20px"
    },
    "blocks": [
        {
            "type": "heading",
            "id":   "newsletter-heading",
            "text": "Stay in the Loop",
            "tag":  "h2",
            "settings": {
                "color":      "#e8e8f0",
                "fontSize":   "28px",
                "fontWeight": "600",
                "textAlign":  "center"
            }
        },
        {
            "type": "text",
            "id":   "newsletter-sub",
            "text": "Subscribe to our newsletter for updates, tips, and news.",
            "settings": {
                "color":      "#8888a0",
                "fontSize":   "15px",
                "lineHeight": "1.55",
                "textAlign":  "center"
            }
        },
        {
            "type":   "form",
            "id":     "newsletter-form-el",
            "action": "",
            "method": "POST",
            "settings": {
                "gap":      "14px",
                "maxWidth": "100%"
            },
            "children": [
                {
                    "type":        "input",
                    "id":          "newsletter-email",
                    "inputType":   "email",
                    "name":        "email",
                    "label":       "Email address",
                    "placeholder": "you@example.com",
                    "required":    true,
                    "settings": {}
                },
                {
                    "type": "button",
                    "id":   "newsletter-submit",
                    "text": "Subscribe",
                    "href": "#",
                    "settings": {
                        "bg":           "#6366f1",
                        "color":        "#ffffff",
                        "padding":      "13px 36px",
                        "fontSize":     "14px",
                        "fontWeight":   "600",
                        "borderRadius": "4px",
                        "letterSpacing": "0.06em",
                        "textAlign":    "center"
                    }
                }
            ]
        }
    ]
}
