{
    "_meta": {
        "name": "Form - Contact",
        "type": "section",
        "description": "Contact form with name, email, message, and submit button"
    },
    "type": "section",
    "id": "contact-form",
    "layout": "column",
    "settings": {
        "bg":       "#0d0d18",
        "padding":  "80px 24px",
        "maxWidth": "600px",
        "align":    "center",
        "gap":      "24px"
    },
    "blocks": [
        {
            "type": "heading",
            "id":   "contact-heading",
            "text": "Get in Touch",
            "tag":  "h2",
            "settings": {
                "color":      "#e8e8f0",
                "fontSize":   "32px",
                "fontWeight": "600",
                "textAlign":  "center"
            }
        },
        {
            "type": "text",
            "id":   "contact-sub",
            "text": "Have a question or want to work together? Fill out the form below.",
            "settings": {
                "color":      "#8888a0",
                "fontSize":   "15px",
                "lineHeight": "1.55",
                "textAlign":  "center"
            }
        },
        {
            "type":   "form",
            "id":     "contact-form-el",
            "action": "",
            "method": "POST",
            "settings": {
                "gap":      "18px",
                "maxWidth": "100%"
            },
            "children": [
                {
                    "type":        "input",
                    "id":          "contact-name",
                    "inputType":   "text",
                    "name":        "name",
                    "label":       "Name",
                    "placeholder": "Your full name",
                    "required":    true,
                    "settings": {}
                },
                {
                    "type":        "input",
                    "id":          "contact-email",
                    "inputType":   "email",
                    "name":        "email",
                    "label":       "Email",
                    "placeholder": "you@example.com",
                    "required":    true,
                    "settings": {}
                },
                {
                    "type":        "input",
                    "id":          "contact-subject",
                    "inputType":   "text",
                    "name":        "subject",
                    "label":       "Subject",
                    "placeholder": "What is this about?",
                    "required":    false,
                    "settings": {}
                },
                {
                    "type":        "input",
                    "id":          "contact-message",
                    "inputType":   "textarea",
                    "name":        "message",
                    "label":       "Message",
                    "placeholder": "Tell us more...",
                    "rows":        5,
                    "required":    true,
                    "settings": {}
                },
                {
                    "type": "button",
                    "id":   "contact-submit",
                    "text": "Send Message",
                    "href": "#",
                    "settings": {
                        "bg":           "#6366f1",
                        "color":        "#ffffff",
                        "padding":      "13px 36px",
                        "fontSize":     "14px",
                        "fontWeight":   "600",
                        "borderRadius": "4px",
                        "letterSpacing": "0.06em",
                        "textAlign":    "center"
                    }
                }
            ]
        }
    ]
}
