{
    "_meta": {
        "name": "Blog - Post Hero",
        "type": "section",
        "description": "Full-width hero for a single blog post page: category, title, meta line (date, author, read time)"
    },
    "type": "section",
    "id": "blog-post-hero",
    "layout": "column",
    "settings": {
        "bg":       "#0a0a14",
        "padding":  "80px 24px 60px",
        "maxWidth": "760px",
        "align":    "center",
        "gap":      "16px"
    },
    "blocks": [
        {
            "type": "text",
            "id":   "bph-category",
            "text": "Design",
            "settings": {
                "color":         "#6366f1",
                "fontSize":      "11px",
                "fontWeight":    "700",
                "letterSpacing": "0.14em",
                "textTransform": "uppercase",
                "textAlign":     "center"
            }
        },
        {
            "type": "heading",
            "id":   "bph-title",
            "text": "How to build a design system from scratch",
            "tag":  "h1",
            "settings": {
                "color":      "#e8e8f0",
                "fontSize":   "42px",
                "fontWeight": "700",
                "textAlign":  "center",
                "lineHeight": "1.2"
            }
        },
        {
            "type": "text",
            "id":   "bph-sub",
            "text": "A practical guide to defining tokens, components, and documentation that scales with your team and grows without breaking.",
            "settings": {
                "color":      "#8888a0",
                "fontSize":   "17px",
                "lineHeight": "1.6",
                "textAlign":  "center"
            }
        },
        {
            "type": "text",
            "id":   "bph-meta",
            "text": "February 20, 2026  |  Crissy Deutsch  |  8 min read",
            "settings": {
                "color":         "#5555a0",
                "fontSize":      "12px",
                "letterSpacing": "0.04em",
                "textAlign":     "center"
            }
        }
    ]
}
