/*
 * Design spec: custom_design_assets/TEST.md
 * Page: Crissy's Style Tool -- web page design (NOT Tauri)
 *
 * Assets:
 *   bg:        ../custom_design_assets/backgrounds/bg-purple.webp
 *   header-img:../custom_design_assets/ui-elements/left-top-header.webp
 *   logo:      ../custom_design_assets/ui-elements/style-tool-logo.webp
 *   footer-img:../custom_design_assets/ui-elements/bottom-right-footer.webp
 *
 * Layout:
 *   - Full-page purple background
 *   - Oversized header -- left-aligned, no traditional nav
 *   - Logo + wordmark in header
 *   - No mid section yet
 *   - Oversized footer -- bottom-right aligned
 */

/* ------------------------------------------------------------------ */
/* Page background                                                      */
/* ------------------------------------------------------------------ */
html,
body {
  min-height: 100%;
  margin: 0;
  padding: 0;
  background-image: url('../custom_design_assets/backgrounds/bg-purple.webp');
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
  /* fallback console hook: check background load in bg-load-check below */
}

/* ------------------------------------------------------------------ */
/* Header -- oversized, left-aligned, no traditional nav               */
/* ------------------------------------------------------------------ */
.site-header {
  position: relative;
  left: 0;
  top: 0;
  width: 100%;
  min-height: 220px;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  overflow: hidden;
  z-index: 10;
}

/* Decorative oversized header image -- anchored top-left */
.site-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: url('../custom_design_assets/ui-elements/left-top-header.webp');
  background-size: cover;
  background-position: left top;
  background-repeat: no-repeat;
  pointer-events: none;
  z-index: 0;
}

/* Header content sits on top of the decorative image */
.site-header__inner {
  position: relative;
  z-index: 1;
  padding: 32px 40px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
}

/* Logo image */
.site-header__logo-img {
  display: block;
  max-width: 180px;
  height: auto;
}

/* Wordmark below/next to logo */
.site-header__wordmark {
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.04em;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
  margin: 0;
}

/* ------------------------------------------------------------------ */
/* Main content area -- no mid section yet, just a spacer              */
/* ------------------------------------------------------------------ */
.site-main {
  min-height: 40px;
  /* placeholder -- no mid section in this design pass */
}

/* ------------------------------------------------------------------ */
/* Footer -- oversized, bottom-right aligned                           */
/* ------------------------------------------------------------------ */
.site-footer {
  position: relative;
  width: 100%;
  min-height: 200px;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  overflow: hidden;
  z-index: 10;
}

/* Decorative oversized footer image -- anchored bottom-right */
.site-footer::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 100%;
  height: 100%;
  background-image: url('../custom_design_assets/ui-elements/bottom-right-footer.webp');
  background-size: cover;
  background-position: right bottom;
  background-repeat: no-repeat;
  pointer-events: none;
  z-index: 0;
}

/* Keep any real footer content above the decorative layer */
.site-footer__inner {
  position: relative;
  z-index: 1;
  padding: 24px 40px;
}

/* ------------------------------------------------------------------ */
/* Debug / fallback error checks (removed at prod, safe to keep)       */
/* ------------------------------------------------------------------ */

/*
  To verify assets are loading, run this one-liner in the browser console:

  ['../custom_design_assets/backgrounds/bg-purple.webp',
   '../custom_design_assets/ui-elements/left-top-header.webp',
   '../custom_design_assets/ui-elements/style-tool-logo.webp',
   '../custom_design_assets/ui-elements/bottom-right-footer.webp'
  ].forEach(src => {
    const img = new Image();
    img.onerror = () => console.error('[asset not found]', src);
    img.onload  = () => console.log('[asset ok]', src, img.naturalWidth + 'x' + img.naturalHeight);
    img.src = src;
  });

  Background attachment 'fixed' may behave differently inside iframes --
  switch to 'scroll' if the background disappears in the style tool preview.
*/
