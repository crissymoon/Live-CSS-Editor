    "ux_patterns": {
        "typography": {
            "scale_ratio": 1.25,
            "base_size_px": 14,
            "line_height_body": 1.55,
            "line_height_heading": 1.2,
            "letter_spacing_label": "0.05em",
            "max_line_length": "68ch",
            "rules": [
                "Use a modular type scale with a 1.25 ratio for consistent heading hierarchy.",
                "Body text: 14px to 16px. Interface labels: 11px to 13px. Monospace code: 12px to 13px.",
                "Limit fonts to two families maximum: one heading, one body. Monospace only for code output.",
                "All uppercase or small-caps labels require letter-spacing of 0.04em to 0.08em.",
                "Paragraph max-width: 60ch to 75ch for optimal readability."
            ]
        },
        "spacing": {
            "base_unit_px": 4,
            "scale": [4, 8, 12, 16, 24, 32, 48, 64],
            "rules": [
                "Group related items with 4px to 8px gaps. Separate sections with 24px to 48px.",
                "Component internal padding: 8px to 16px.",
                "Minimum 16px safe margin from viewport edges at all times.",
                "Toolbar heights: 36px compact, 44px standard, 54px relaxed."
            ]
        },
        "layout": {
            "z_layers": {
                "base": 0,
                "raised": 10,
                "floating": 100,
                "modals": 1000,
                "toasts": 9999
            },
            "rules": [
                "Left-align text and labels. Center only for hero content or very short labels.",
                "Sidebar widths: 220px to 280px. Prioritize the content area.",
                "Sticky toolbars are acceptable for editors. Avoid fixed headers on nested scrollable areas.",
                "Grid: 12-column base. Collapse to 4 columns below 600px viewport width.",
                "Panel minimum width: 240px. Panel maximum suggested width: 460px."
            ]
        },
        "motion": {
            "durations_ms": {
                "micro": 100,
                "interaction": 140,
                "panel": 240,
                "modal": 180
            },
            "easings": {
                "enter": "cubic-bezier(0.0, 0.0, 0.2, 1)",
                "exit": "cubic-bezier(0.4, 0.0, 1, 1)",
                "standard": "cubic-bezier(0.4, 0.0, 0.2, 1)"
            },
            "rules": [
                "Entrance: ease-out. Exit: ease-in. State transitions: ease-in-out.",
                "Never animate two conflicting properties in opposite directions on the same element.",
                "Always respect prefers-reduced-motion. Provide an instant fallback.",
                "Do not animate color changes when color is the primary information carrier."
            ]
        },
        "feedback": {
            "rules": [
                "Every click or keyboard action must produce a sub-100ms visible response.",
                "Loading indicators: delay onset by 300ms to avoid flicker on fast operations.",
                "Error messages belong inline near the cause, not only in a remote status bar.",
                "Success feedback: brief (1500ms to 2000ms) and non-blocking.",
                "Errors persist until explicitly dismissed or corrected.",
                "Disabled elements must have 40 to 50 percent reduced opacity and cursor: not-allowed."
            ]
        },
        "color_usage": {
            "rules": [
                "All color values must live in CSS custom properties. No hardcoded hex in component stylesheets.",
                "Reserve the accent color for the single most important interactive element per view.",
                "Error state: red hue only. Success: green only. Warning: amber only. Never reuse for decoration.",
                "Minimum contrast ratios: 4.5:1 body text, 3:1 large text and UI components (WCAG AA).",
                "Dark themes: avoid pure black (#000). Use near-black with a subtle hue (e.g. #0d0e12).",
                "Background layers should differ by at least visible luminance steps to establish hierarchy."
            ]
        },
        "density": {
            "compact":  { "font_px": 11, "v_pad_px": 4,  "h_pad_px": 6  },
            "standard": { "font_px": 13, "v_pad_px": 6,  "h_pad_px": 10 },
            "relaxed":  { "font_px": 15, "v_pad_px": 10, "h_pad_px": 14 }
        },
        "accessibility": {
            "rules": [
                "All interactive elements must have a visible focus-visible outline. Never use outline: none alone.",
                "Color must not be the sole means of conveying information. Pair with text, icon, or shape.",
                "ARIA roles and labels are required on all custom widgets.",
                "Touch targets: minimum 44x44px in any mobile context.",
                "DOM reading order must match visual order."
            ]
        }
    },

    "cultural_adjustments": {
        "East Asia": {
            "font_stack": "system-ui, 'Hiragino Kaku Gothic Pro', 'Noto Sans JP', 'Noto Sans CJK SC', sans-serif",
            "notes": "Higher UI density is acceptable and expected. Grid-heavy layouts are common. Red can carry positive connotations.",
            "preferred_palettes": ["volcanic-red", "night-ink", "muted-moss", "ink-sand"]
        },
        "Middle East / North Africa": {
            "direction": "rtl",
            "font_stack": "system-ui, 'Segoe UI', 'Noto Sans Arabic', 'Arabic UI Text', sans-serif",
            "notes": "RTL layout is required. Green carries strong positive association. Geometric ornament is culturally valued.",
            "preferred_palettes": ["muted-moss", "circuit-green", "slate-sand"]
        },
        "South Asia": {
            "font_stack": "system-ui, 'Noto Sans', 'Devanagari UI', sans-serif",
            "notes": "Vibrant accent colors are accepted. High density is common. Warm palettes resonate.",
            "preferred_palettes": ["volcanic-red", "warm-cedar", "brass-library"]
        },
        "Northern Europe": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif",
            "notes": "Minimalism and negative space are design values. Neutral palettes are strongly preferred.",
            "preferred_palettes": ["arctic-dawn", "bone-steel", "muted-moss", "slate-sand"]
        },
        "Western Europe / Germanic": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', Helvetica, Arial, sans-serif",
            "notes": "Clean typography and strong grid structure. Pragmatic over decorative.",
            "preferred_palettes": ["bone-steel", "arctic-dawn", "brass-library", "slate-sand"]
        },
        "Western Europe / Latin": {
            "font_stack": "system-ui, -apple-system, Georgia, 'Times New Roman', serif",
            "notes": "Slightly warmer accents are acceptable. A degree of typographic ornament is appreciated.",
            "preferred_palettes": ["warm-cedar", "rose-ash", "brass-library", "ink-sand"]
        },
        "Eastern Europe": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', sans-serif",
            "notes": "Dark themes are common in developer tools. High contrast and sharp edges are preferred.",
            "preferred_palettes": ["night-ink", "volcanic-red", "circuit-green", "steel-violet"]
        },
        "Latin America / South": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', sans-serif",
            "notes": "Warm palettes are preferred. Contrast between UI layers should be high.",
            "preferred_palettes": ["warm-cedar", "volcanic-red", "rose-ash"]
        },
        "Latin America / Caribbean": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', sans-serif",
            "notes": "Warm and approachable palette. Slightly higher saturation is accepted.",
            "preferred_palettes": ["warm-cedar", "rose-ash", "volcanic-red"]
        },
        "Australasia": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', sans-serif",
            "notes": "Similar preferences to North American English. Earth tones carry cultural resonance.",
            "preferred_palettes": ["muted-moss", "warm-cedar", "bone-steel"]
        },
        "Sub-Saharan Africa": {
            "font_stack": "system-ui, -apple-system, 'Noto Sans', sans-serif",
            "notes": "Bold, saturated accent colors are valued. Clear hierarchy with strong contrast.",
            "preferred_palettes": ["volcanic-red", "circuit-green", "warm-cedar"]
        },
        "North America / English": {
            "font_stack": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
            "notes": "Broad acceptance of most styles. Functional clarity is the highest priority.",
            "preferred_palettes": ["night-ink", "bone-steel", "slate-sand", "arctic-dawn", "steel-violet"]
        }
    },

    "harmony_nudge": {
        "_note": "Per-theme color harmony nudge configuration. Controls how theme-randomizer.php offsets colors when mode=nudge is invoked. Nudges are small HSL deltas that shift the palette slightly without destroying the theme character.",
        "global_defaults": {
            "hue_range":        8,
            "sat_range":        5,
            "light_range":      5,
            "max_iterations":   1
        },
        "theme_overrides": {
            "quill-cartesian": {
                "hue_range":   8,
                "sat_range":   5,
                "light_range": 5,
                "notes": "Warm analogous family (hue 30-50). Accent navy at 220-230. Drama burgundy at 345-355. Small nudges preserve Renaissance parchment feel."
            },
            "neon-grid": {
                "hue_range":   12,
                "sat_range":   4,
                "light_range": 6,
                "notes": "Neon palette tolerates slightly wider hue swings. Keep saturation tight to preserve the electric quality."
            },
            "atom-age": {
                "hue_range":   6,
                "sat_range":   4,
                "light_range": 4,
