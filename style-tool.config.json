{
  "_comment": "Crissy's Style Tool -- project file structure map and runtime config.",
  "_doc": "Edit this file to adapt the tool to any project root. All paths are relative to the project root unless marked absolute.",
  "version": "1.0.0",
  "tool": "crissys-style-tool",

  "project": {
    "name": "Crissy's Style Tool",
    "root": ".",
    "entry": "index.php",
    "description": "Live HTML / CSS / JS editor with VS Code bridge and AI agent."
  },

  "mode": "dev",

  "map": {
    "_comment": "Describes every file and directory the tool needs. status: required | optional | bridge",
    "files": [
      { "path": "index.php",        "role": "entry-point",  "status": "required", "note": "Main app shell. Loads data/ and renders the HTML skeleton." },
      { "path": "style.css",        "role": "base-styles",  "status": "required", "note": "Root stylesheet imported by index.php." },
      { "path": "push-pull.php",    "role": "cli-sync",     "status": "optional", "note": "CLI helper: php push-pull.php push|pull|list" },
      { "path": "god_funcs.py",     "role": "dev-util",     "status": "optional", "note": "Python dev utilities." },
      { "path": "security_ck.py",   "role": "dev-util",     "status": "optional", "note": "Security audit helper." }
    ],
    "dirs": {
      "data": {
        "status": "required",
        "role": "php-data",
        "note": "PHP data files served to index.php: css-properties.php, property-values.php, default-content.php, stylesheets.php",
        "required_files": [
          "css-properties.php",
          "property-values.php",
          "default-content.php"
        ],
        "optional_files": [
          "stylesheets.php",
          "property-values.php"
        ]
      },
      "css": {
        "status": "required",
        "role": "css-modules",
        "note": "Modular CSS loaded by index.php.",
        "required_files": [
          "base.css",
          "layout.css",
          "header.css",
          "modal.css",
          "scrollbar.css",
          "responsive.css"
        ],
        "optional_files": [
          "wireframe.css",
          "agent.css",
          "ai-chat.css",
          "color-tools.css",
          "fuzzy.css",
          "gutter.css",
          "info-bar.css",
          "native-bridge.css"
        ]
      },
      "js": {
        "status": "required",
        "role": "js-modules",
        "note": "All JS modules. Load order matters -- cdn-loader first, app.js last.",
        "required_files": [
          "cdn-loader.js",
          "utils.js",
          "storage.js",
          "editor.js",
          "app.js"
        ],
        "optional_files": [
          "color-harmony.js",
          "color-swatch.js",
          "editor-search.js",
          "fuzzy.js",
          "gutter.js",
          "indent-guide.js",
          "modal-load.js",
          "modal-save.js",
          "native-bridge.js",
          "property-lookup.js",
          "size-slider.js",
          "theme-randomizer.js",
          "wireframe.js",
          "agent.js",
          "ai-chat.js"
        ],
        "subdirs": {
          "editor":   { "status": "optional", "note": "Editor sub-modules: goto-css.js, lint.js, preview.js" },
          "agent":    { "status": "optional", "note": "Agent system: agent-core.js, agent-ui.js, agent-run.js, etc." },
          "wireframe":{ "status": "optional", "note": "Wireframe sub-modules." },
          "theme_randomizer": { "status": "optional", "note": "Theme randomizer helpers." }
        }
      },
      "vendor": {
        "status": "required",
        "role": "third-party",
        "note": "Third-party libraries. CodeMirror lives in vendor/codemirror/. CSS linters in vendor/linters/.",
        "required_subdirs": ["codemirror"],
        "optional_subdirs": ["linters"]
      },
      "ai": {
        "status": "optional",
        "role": "ai-backend",
        "note": "AI backends (anthropic.php, openai.php, deepseek.php) and their config. Disable this dir to run without AI features.",
        "required_files": [],
        "optional_files": [
          "config.json",
          "config.php",
          "anthropic.php",
          "openai.php",
          "deepseek.php",
          "phrases.php",
          "context-time.php",
          "model-context.json"
        ]
      },
      "style-sheets": {
        "status": "optional",
        "role": "stylesheet-library",
        "note": "Saved CSS themes and stylesheets managed by the tool. Can be empty on first run.",
        "auto_create": true
      },
      "vscode-bridge": {
        "status": "bridge",
        "role": "vscode-sync",
        "note": "VS Code Copilot two-way sync. Set up via setup.php or by extracting vscode-bridge.zip.",
        "auto_create": true,
        "required_subdirs": ["api", "js", "data", "projects"],
        "required_files": [
          "js/bridge-sync.js",
          "api/projects.php",
          "data/project-update-signal.json",
          "data/project-update-ack.json"
        ],
        "setup_via": "setup.php",
        "zip_name": "vscode-bridge.zip"
      }
    }
  },

  "modes": {
    "dev": {
      "_comment": "Development mode: debug output on, source maps, relaxed CSP, no minification.",
      "debug":           true,
      "source_maps":     true,
      "hot_reload":      true,
      "check_structure": true,
      "server_port":     9879,
      "error_reporting": "E_ALL",
      "display_errors":  true,
      "csp_mode":        "relaxed",
      "log_level":       "verbose",
      "enable_ai":       true,
      "wasm_enabled":    false
    },
    "build": {
      "_comment": "Build / production mode: minification flags, strict CSP, no debug output.",
      "debug":           false,
      "source_maps":     false,
      "hot_reload":      false,
      "check_structure": false,
      "server_port":     443,
      "error_reporting": "0",
      "display_errors":  false,
      "csp_mode":        "strict",
      "log_level":       "error",
      "enable_ai":       true,
      "wasm_enabled":    false,
      "output_dir":      "dist",
      "minify_css":      false,
      "minify_js":       false,
      "bundle_vendor":   false,
      "exclude_dirs":    ["dev-tools", "imgui-browser", "dev-browser", "debug-tool", "c_tools", "logs", ".git"]
    }
  },

  "vscode_bridge": {
    "api_endpoint":     "/vscode-bridge/api/projects.php",
    "poll_interval_ms": 4000,
    "default_project":  "crissys-style-tool",
    "projects_dir":     "vscode-bridge/projects",
    "data_dir":         "vscode-bridge/data",
    "sqlite_db":        "vscode-bridge/data/projects.db"
  },

  "feature_flags": {
    "_comment": "Toggle individual features without removing their files.",
    "ai_chat":          true,
    "agent":            true,
    "wireframe":        true,
    "color_harmony":    true,
    "indent_guides":    true,
    "fuzzy_autocomplete": true,
    "vscode_bridge":    true,
    "style_sheets":     true,
    "theme_randomizer": true
  }
}
