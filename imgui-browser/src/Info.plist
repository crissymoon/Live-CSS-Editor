<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.crissystyle.imgui-browser</string>
    <key>CFBundleName</key>
    <string>Crissy's Style Tool</string>
    <key>CFBundleDisplayName</key>
    <string>Crissy's Style Tool</string>
    <key>CFBundleExecutable</key>
    <string>imgui_browser</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- ATS: allow arbitrary HTTP loads for general browsing, but enforce
         certificate transparency on HTTPS connections.
         Localhost is explicitly allowed for the dev PHP/Node servers. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Allow HTTP navigation to arbitrary remote sites (general browser) -->
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <!-- Require Certificate Transparency logging for all HTTPS connections.
             CT is enforced by the Apple CT policy on macOS 10.15+ -- this key
             makes it explicit so future OS changes cannot relax it. -->
        <key>NSRequiresCertificateTransparency</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <!-- Local dev servers (PHP / Node) always run over HTTP -->
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <false/>
            </dict>
            <key>127.0.0.1</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Privacy usage strings needed for camera/mic access (LinkedIn calls, etc.) -->
    <key>NSCameraUsageDescription</key>
    <string>Camera access is required for video calls on pages such as LinkedIn and Google Meet.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Microphone access is required for audio and video calls.</string>
</dict>
</plist>
