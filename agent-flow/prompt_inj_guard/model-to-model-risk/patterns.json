{
  "_comment": "Model-to-model attack pattern database. Hot-reloaded on mtime change.",
  "_version": "1.0.0",

  "attack_patterns": [

    {
      "id": "m2m_001",
      "label": "role_override",
      "severity": 9,
      "weight": 1.0,
      "description": "Attempts to override system prompt or reassign the model identity",
      "patterns": [
        "ignore\\s+[\\w\\s]{0,25}?(your|all previous|prior|previous) (instructions|rules|guidelines|constraints|system prompt)",
        "(ignore|disregard|stop following) (your|all|every|any|the|all previous|all of your|all prior) (instructions|rules|guidelines|constraints|training|system prompt)",
        "forget (everything|all|your prior|your previous) (you were told|instructions|context|training)",
        "your (new|real|true|actual)[\\w\\s]{0,20}?(instructions|role|purpose|directive|system prompt)[\\w\\s]{0,10}?(is|are|will be|from now on)",
        "you are now (a|an|no longer|acting as|playing the role of|pretending to be)",
        "from (now on|this point|this moment) (you are|you will|treat yourself as|act as)",
        "pretend (you are|you have no|you don'?t have|there are no) (restrictions|limitations|rules|filters|guidelines)",
        "act as (if you have no|without any|a version of yourself without) (restrictions|filters|guidelines|rules|safety)"
      ]
    },

    {
      "id": "m2m_002",
      "label": "jailbreak_persona",
      "severity": 9,
      "weight": 1.0,
      "description": "DAN-style and persona-based jailbreaks",
      "patterns": [
        "\\bDAN\\b.*\\bdo anything now\\b",
        "\\bDANmode\\b",
        "jailbreak (mode|enabled|activated|protocol)",
        "developer (mode|override|access|console) (enabled|on|unlocked|activated)",
        "maintenance (mode|override|access) (enabled|on|unlocked)",
        "god (mode|level) (enabled|on|access|override)",
        "super (user|admin|mode|access) (mode|enabled|on|override|protocol)",
        "(bypass|disable|turn off|remove)\\s+[\\w\\s]{0,30}?(filters|restrictions|guardrails|safeguards|safety blocks|content blocks)",
        "you (have|now have|are given) (unlimited|unrestricted|full|complete|absolute) (access|permission|authority|capability)"
      ]
    },

    {
      "id": "m2m_003",
      "label": "command_injection",
      "severity": 10,
      "weight": 1.0,
      "description": "Model tricked into running shell commands, code execution, or OS-level instructions",
      "patterns": [
        "run (this|the following|a|the) (command|shell|script|code|bash|python|powershell)",
        "execute (this|the|the following|a) (command|shell|script|code|bash|python|powershell|sql)",
        "\\$\\([^)]{0,120}\\)",
        "`[^`]{0,120}`",
        "os\\.system\\s*\\(",
        "subprocess\\.(run|call|Popen|check_output)\\s*\\(",
        "eval\\s*\\([^)]{0,200}\\)",
        "exec\\s*\\([^)]{0,200}\\)",
        "__import__\\s*\\(",
        "(curl|wget|nc|netcat|nmap|bash|sh|zsh|powershell)\\s+(http[s]?://|[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3})",
        "rm\\s+-rf\\s+",
        "chmod\\s+[0-9]{3,4}\\s+",
        "sudo\\s+(rm|chmod|chown|bash|sh|curl|wget|python|pip)"
      ]
    },

    {
      "id": "m2m_004",
      "label": "encoding_obfuscation",
      "severity": 8,
      "weight": 0.90,
      "description": "Obfuscation via encoding, leetspeak, homoglyphs, or whitespace injection to evade filters",
      "patterns": [
        "base64\\s*\\.\\s*(decode|b64decode)",
        "\\\\x[0-9a-fA-F]{2}(\\\\x[0-9a-fA-F]{2}){4,}",
        "\\\\u[0-9a-fA-F]{4}(\\\\u[0-9a-fA-F]{4}){3,}",
        "%[0-9a-fA-F]{2}(%[0-9a-fA-F]{2}){4,}",
        "(chr\\(\\d+\\)\\s*[+.]\\s*){3,}",
        "rot13|caesar cipher.*decode|decode.*caesar",
        "hex\\s*(decode|to string|values to|encoded)",
        "unicode\\s*(escape|encoded|decode).*inject"
      ]
    },

    {
      "id": "m2m_005",
      "label": "token_smuggling",
      "severity": 8,
      "weight": 0.85,
      "description": "Prompt injection via nested instructions, fake system tags, or context manipulation",
      "patterns": [
        "<\\s*system[_ ]?(prompt|instructions|message|override)?\\s*>",
        "<\\s*/\\s*system\\s*>",
        "\\[SYSTEM\\]",
        "\\[INST\\]",
        "\\[SYS\\]",
        "<<SYS>>",
        "<\\|im_start\\|>\\s*system",
        "<\\|im_end\\|>",
        "\\[OVERRIDE\\]",
        "\\[ADMIN\\]",
        "\\[ROOT\\]",
        "\\[DEVELOPER\\]",
        "---\\s*(END OF CONTEXT|NEW INSTRUCTION|SYSTEM MESSAGE|OVERRIDE|INJECTION)\\s*---",
        "====\\s*(NEW CONTEXT|SYSTEM OVERRIDE|ADMIN)\\s*===="
      ]
    },

    {
      "id": "m2m_006",
      "label": "data_exfiltration",
      "severity": 10,
      "weight": 1.0,
      "description": "Attempts to extract training data, system prompts, or model internals",
      "patterns": [
        "repeat (the|your|all|everything in the) (system prompt|context window|training data|previous instructions|initial instructions)",
        "print (your|the|all) (system prompt|initial instructions|training|hidden instructions|context)",
        "what (is|are|was|were) (your|the) (system prompt|initial instructions|hidden instructions|original instructions)",
        "tell me[\\w\\s]{0,30}?(hidden|actual|real|secret|original|initial)[\\w\\s]{0,20}?(prompt|instructions|system message|context)",
        "output (your|the|all|full) (system prompt|initial context|training examples|hidden instructions)",
        "show (me|us)[\\w\\s]{0,20}?(entire|full|complete|actual|real|hidden)[\\w\\s]{0,20}?(system prompt|context|instructions)",
        "leak (your|the|any|all|my|every) (training data|system prompt|context|instructions|memory|conversation history)"
      ]
    },

    {
      "id": "m2m_007",
      "label": "recursive_prompt",
      "severity": 8,
      "weight": 0.85,
      "description": "Prompts designed to make the model generate adversarial prompts for other models",
      "patterns": [
        "(write|generate|create)\\s+[\\w\\s]{0,20}?(prompt|jailbreak|bypass|adversarial prompt|attack prompt)[\\w\\s]{0,30}?(bypass|fool|trick|deceive|manipulate|jailbreak)[\\w\\s]{0,20}?(ai|llm|model|chatbot|gpt|claude|gemini|filter|safety)",
        "how (would|do|can|could|should) (you|i|someone|an attacker|a model) (bypass|jailbreak|trick|fool|manipulate|exploit) (a\\s+|an\\s+|the\\s+|another\\s+)?(ai|llm|model|chatbot|assistant|gpt|claude|gemini|filter)",
        "craft[\\w\\s]{0,20}?(prompt|message|input)[\\w\\s]{0,20}?(tricks|fools|bypasses|evades|confuses|manipulates)[\\w\\s]{0,20}?(model|ai|llm|assistant|filter|guard)"
      ]
    },

    {
      "id": "m2m_008",
      "label": "machine_repetition_probe",
      "severity": 7,
      "weight": 0.80,
      "description": "Structured probing patterns typical of automated model-driven enumeration",
      "patterns": [
        "^(yes|no|true|false|0|1)[.\\s]*(yes|no|true|false|0|1)[.\\s]*(yes|no|true|false|0|1)",
        "(try|attempt|option|variant|version|iteration|probe|test)\\s*[#\\-]?\\s*\\d+\\s*:",
        "^\\s*\\d+\\s*\\.\\s*.{5,80}\\n\\s*\\d+\\s*\\.",
        "systematically (try|test|probe|enumerate|iterate|attempt|check) (every|all|each|multiple)",
        "step (\\d+|one|two|three|four|five) of (\\d+|many):\\s*(try|attempt|inject|bypass|override)"
      ]
    },

    {
      "id": "m2m_009",
      "label": "privilege_escalation",
      "severity": 9,
      "weight": 0.95,
      "description": "Attempts to claim elevated permissions, admin status, or special access",
      "patterns": [
        "i (am|have been granted|have) (admin|administrator|root|superuser|developer|operator|owner) (access|privileges|permissions|status|rights)",
        "this (is|was) (authorized|approved|permitted|sanctioned) by (your|the|an) (developer|creator|operator|admin|owner|team|company)",
        "you (have|are) (authorized|permitted|allowed|granted) to (bypass|ignore|remove|disable) (your|all|the) (restrictions|guidelines|filters|safety)",
        "emergency (override|access|mode|protocol) (code|key|token|phrase)\\s*[:=]",
        "master (key|password|override|code|token|phrase)\\s*[:=]",
        "secret (key|code|token|passphrase|phrase|override)\\s*[:=]\\s*['\"]?[A-Za-z0-9_\\-]{4,}"
      ]
    }

  ],

  "high_entropy_thresholds": {
    "shannon_entropy_min": 3.5,
    "symbol_ratio_high": 0.70,
    "symbol_ratio_min": 0.30,
    "short_text_char_limit": 40,
    "max_safe_repeat_ratio": 0.40
  },

  "session_thresholds": {
    "window_size": 20,
    "window_seconds": 300,
    "similarity_block_threshold": 0.72,
    "hard_block_after_n_similar": 3,
    "secure_mode_trigger_count": 5,
    "secure_mode_cooldown_seconds": 600
  }
}
