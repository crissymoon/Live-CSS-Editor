# Widevine CDM -- Google proprietary DRM binary, cannot be distributed publicly
dev-browser/WidevineCdm/
dev-browser/widevine/
*.dylib
*.dylib.sig

# Python virtual environments
dev-browser/venv/
dev-browser/.venv/
.venv/

# dev-browser build output and bundled binaries
dev-browser/bin/php
dev-browser/bin/*.dylib
dev-browser/build/
dev-browser/dist/

# C++ render core build artifacts
dev-browser/render_core/build/
*.o
*.o.d

# WASM compiled outputs -- regenerated by render_core/build.sh
*.wasm
dev-browser/src/render_core.js

# db-browser build artifacts and binaries
dev-tools/db-browser/build/
dev-tools/db-browser/*.o
dev-tools/db-browser/databases/*.db
dev-tools/db-browser/databases/*.db.enc
dev-tools/db-browser/databases/*.tmp
dev-tools/db-browser/logs/*.log

# SQLite journal files (never commit WAL/SHM -- they are OS-level lock artifacts)
*.db-shm
*.db-wal

# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Browser runtime data -- URL history, private browsing data
dev-browser/url_history.json
dev-browser/modules/url_history.json

# Environment and secrets
.env
.env.*
*.env
secrets.*
config.local.*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor/IDE directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs and temp files
*.log
*.tmp
*.swp
*.swo
*~

# PHP cache
/vendor/

# Build output
/dist/
/build/

# imgui-browser -- compiled artifacts and vendored C++ deps fetched at build time
imgui-browser/build/
imgui-browser/vendor/

# Node..
node_modules/

# Tauri
**/src-tauri/target/
**/src-tauri/www/
**/src-tauri/gen/

# External project symlinks - worked on locally but not part of this repo
moon-lang
moon-lang/
gram-model
gram-model/

# Style-sheets test/backup artifacts
style-sheets/test-preview-output.html
style-sheets/test-preview-debug.log
style-sheets/backups/
style-sheets/TESTING_DIR_4_LRN.TXT

# prompt_inj_guard -- model weights are too large for git
prompt_inj_guard/model/spam_injection_model/
prompt_inj_guard/model/spam_injection_model/**
xcm_auth/dev-credentials.json

# code-review generated reports and local UI state
dev-tools/code-review/reports/
dev-tools/code-review/.browser_recent_paths
dev-tools/code-review/.terminal_state.lua
